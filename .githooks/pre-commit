#!/usr/bin/env bash
#
# Pre-commit hook: checks for secrets and linting issues
# 1. Blocks commits containing secrets (passwords, API keys, tokens)
# 2. Runs ruff for style/formatting checks
# 3. Runs mypy for type checking
#

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

BLOCKED=0

# Get list of staged files (excluding deleted files and binary files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Patterns that indicate hardcoded secrets
declare -a PATTERN_LABELS=(
    "API Key (prefixed)"
    "AWS Access Key"
    "Private Key block"
    "Password assignment"
    "Credentials in URL"
    "Bearer Token"
    "Basic Auth header"
    "Hardcoded JWT"
)

declare -a PATTERNS=(
    '(api[_-]?key|apikey|api[_-]?secret|secret[_-]?key)\s*[=:]\s*["\x27][A-Za-z0-9_.+/=-]{16,}["\x27]'
    'AKIA[0-9A-Z]{16}'
    '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
    '(password|passwd|pwd)\s*[=:]\s*["\x27][^\s"'\'']{6,}["\x27]'
    '://[a-zA-Z0-9_]+:[^@\s]{6,}@[a-zA-Z0-9]'
    'Bearer\s+[A-Za-z0-9._-]{20,}'
    'Basic\s+[A-Za-z0-9+/=]{20,}'
    'eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}'
)

# Files/patterns to always skip (not secrets — uses regex, not globs)
SKIP_REGEX='\.env\.example$|^\.githooks/|IMPLEMENTATION_PLAN\.md|README\.md|\.lock$|package-lock\.json|\.md$|conftest\.py|\.ya?ml$'

for file in $STAGED_FILES; do
    # Skip the hook itself, example files, docs, configs, lock files
    if echo "$file" | grep -qE "$SKIP_REGEX"; then
        continue
    fi

    # Skip files that don't exist (shouldn't happen with --diff-filter=d, but safety)
    if [ ! -f "$file" ]; then
        continue
    fi

    # Get the staged content (not working tree)
    CONTENT=$(git show ":$file" 2>/dev/null || true)
    if [ -z "$CONTENT" ]; then
        continue
    fi

    for i in "${!PATTERNS[@]}"; do
        MATCHES=$(echo "$CONTENT" | grep -nE "${PATTERNS[$i]}" 2>/dev/null || true)
        if [ -n "$MATCHES" ]; then
            # Check if it's in a comment or is a placeholder
            while IFS= read -r match_line; do
                # Skip lines that are clearly placeholders or comments
                if echo "$match_line" | grep -qiE '(your_|change.me|example|placeholder|todo|fixme|xxx|dummy|test-|fake|mock|localhost|127\.0\.0\.1|0\.0\.0\.0)'; then
                    continue
                fi
                # Skip comment lines
                if echo "$match_line" | grep -qE '^\s*(#|//|/\*|\*|<!--)'; then
                    continue
                fi

                echo -e "${RED}BLOCKED:${NC} Potential secret found in ${YELLOW}$file${NC}"
                echo -e "  Pattern: ${PATTERN_LABELS[$i]}"
                echo -e "  Line:    $match_line"
                echo ""
                BLOCKED=1
            done <<< "$MATCHES"
        fi
    done
done

# Check for .env files being committed (should NEVER happen)
ENV_FILES=$(echo "$STAGED_FILES" | grep -E '^\.env$|^\.env\.' | grep -v '.env.example' || true)
if [ -n "$ENV_FILES" ]; then
    echo -e "${RED}BLOCKED:${NC} Attempting to commit .env file(s):"
    echo "$ENV_FILES"
    echo -e "These files contain secrets and must NEVER be committed."
    BLOCKED=1
fi

# Check for key/cert files
KEY_FILES=$(echo "$STAGED_FILES" | grep -E '\.(pem|key|cert|p12|pfx|jks)$' || true)
if [ -n "$KEY_FILES" ]; then
    echo -e "${RED}BLOCKED:${NC} Attempting to commit key/certificate file(s):"
    echo "$KEY_FILES"
    BLOCKED=1
fi

if [ $BLOCKED -ne 0 ]; then
    echo ""
    echo -e "${RED}=========================================${NC}"
    echo -e "${RED}COMMIT BLOCKED: Secrets detected${NC}"
    echo -e "${RED}=========================================${NC}"
    echo ""
    echo "Remove the secrets from the staged files before committing."
    echo "If this is a false positive, you can bypass with: git commit --no-verify"
    echo "  (but ONLY if you are 100% sure these are not real secrets)"
    exit 1
fi

echo "✅ Secrets check passed"
exit 0
